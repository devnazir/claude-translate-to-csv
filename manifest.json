{
	"manifest_version": 3,
	"name": "Pickslate",
	"version": "2.0.0",
	"description": "Pick any text elements on a webpage and instantly translate them into multiple languages. Export results as CSV or JSON.",
	"permissions": [
		"contextMenus",
		"storage",
		"activeTab",
		"scripting",
		"clipboardWrite"
	],
	"host_permissions": [
		"<all_urls>",
		"https://api.anthropic.com/*",
		"https://models.inference.ai.azure.com/*",
		"https://api.openai.com/*",
		"https://generativelanguage.googleapis.com/*",
		"https://api.groq.com/*",
		"https://openrouter.ai/*"
	],
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["<all_urls>"],
			"js": ["content.js"],
			"css": ["content.css"]
		}
	],
	"action": {
		"default_popup": "settings.html",
		"default_title": "Translate UI — Settings"
	},
	"icons": {
		"16": "icon.png",
		"48": "icon.png",
		"128": "icon.png"
	}
}
